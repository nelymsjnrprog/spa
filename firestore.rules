rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS & CONSTANTS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct check for hardcoded system owner credentials
      let isOwner = request.auth.uid == 'lcfFiLMTu3WULPpiXb4joCX1W3s1' || 
                    (request.auth.token.email != null && request.auth.token.email.lower() == 'nelymsjnr@gmail.com');
      
      // Secondary check against the users collection role field
      return isOwner || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSuperAdmin() {
      let isOwner = request.auth.uid == 'lcfFiLMTu3WULPpiXb4joCX1W3s1' || 
                    (request.auth.token.email != null && request.auth.token.email.lower() == 'nelymsjnr@gmail.com');
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isOwner || (
        isAdmin() && (
          !exists(userDoc) ||
          get(userDoc).data.get('adminPermission', 'super_admin') == 'super_admin'
        )
      );
    }

    function isNotBlocked() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userDoc) || get(userDoc).data.get('isBlocked', false) == false;
    }

    // Fix: hasValidSession is now safe for new students who have no currentSessionId field yet.
    // If the field does not exist on the user doc, we allow the session to pass through.
    function hasValidSession() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = get(userDoc).data;
      // If the user has no currentSessionId set yet (new student), bypass the check
      return !exists(userDoc) ||
             !('currentSessionId' in userData) ||
             userData.currentSessionId == null ||
             request.resource.data.sessionId == userData.currentSessionId;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasLevelAccess() {
      // Access is granted if:
      // 1. User is an Admin (bypasses level-based payment locks)
      // 2. OR the student has an 'active' membership status
      // 3. OR the student has the legacy 'paid: true' flag (backward compatibility)
      //    This matches the app-level checkAccess() in membershipService.ts
      
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;

      return isAdmin() ||
             userDoc.get('membershipStatus', 'pending') == 'active' ||
             userDoc.get('paid', false) == true;
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // User Profiles
    match /users/{userId} {
      allow get: if isSelf(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSelf(userId) && request.resource.data.role == 'student');
      allow update: if isAdmin() || (
        isSelf(userId) && 
        isNotBlocked() && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.email == resource.data.email &&
        (
          !('level' in resource.data) || 
          resource.data.level == 'Pending' || 
          request.resource.data.level == resource.data.level
        ) &&
        (
          !('membershipStatus' in resource.data) ||
          request.resource.data.get('membershipStatus', 'pending') == resource.data.get('membershipStatus', 'pending') ||
          (resource.data.get('membershipStatus', 'pending') == 'pending' && request.resource.data.membershipStatus == 'active')
        )
      );
      allow delete: if isAdmin();
    }

    // Quiz Modules (Exams)
    match /quizzes/{quizId} {
      allow get: if isSignedIn() && (isAdmin() || (resource.data.published == true && isNotBlocked() && hasLevelAccess()));
      allow list: if isSignedIn() && (isAdmin() || (isNotBlocked() && hasLevelAccess())); 
      allow create, update, delete: if isAdmin();
    }

    // Question Bank
    match /questions/{questionId} {
      allow read, list: if isSignedIn() && (isAdmin() || hasLevelAccess());
      allow create, update, delete: if isAdmin();
    }

    // Student Submissions
    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (isAdmin() || (request.auth.uid == resource.data.studentId && isNotBlocked() && hasLevelAccess()));
      // Students can only list their own submissions; admins can list all
      allow list: if isSignedIn() && (isAdmin() || (isNotBlocked() && hasLevelAccess()));
      // Create: student must own the submission. New students (no currentSessionId) are also allowed.
      allow create: if isSignedIn() && 
                       request.resource.data.studentId == request.auth.uid && 
                       isNotBlocked() && 
                       hasLevelAccess() &&
                       (isAdmin() || hasValidSession());
      // Update: students can only update active submissions and only specific fields
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == resource.data.studentId && 
        isNotBlocked() &&
        hasLevelAccess() &&
        hasValidSession() &&
        resource.data.status == 'active' &&
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'answers', 'status', 'score', 'completedAt',
          'violations', 'lastViolationAt', 'sessionId',
          'lastActive', 'currentQuestionIndex',
          'isIncompleteAttempt', 'correctCount', 'totalQuestions',
          'studentLevel', 'studentInstitution'
        ]))
      );
      allow delete: if isAdmin();
    }

    // Institution Configuration
    match /institutionConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Institutions List
    match /institutions/{instId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Membership Settings
    match /membership_settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Payment Records
    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || !('userId' in request.resource.data));
    }

    // Admin Logs
    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Support Inquiries
    match /Support/{inquiryId} {
      allow create: if true; // Public contact form
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /Library/{resourceId} {
      // Students can only read/list published resources
      allow read, list: if isSignedIn() && (isAdmin() || resource.data.published == true);
      allow create, update, delete: if isAdmin();
    }
  }
}