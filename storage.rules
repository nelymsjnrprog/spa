rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // System Owner Bypass
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == 'lcfFiLMTu3WULPpiXb4joCX1W3s1' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'nelymsjnr@gmail.com')
      );
    }

    // Specific Collection Rules
    match /exam_files/{quizId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }

    match /library/{level}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // App logic restricts this further to admins
    }
  }
}